# ============================================
# RepoHealth Project .gitignore
# Unified .gitignore for backend (Python/FastAPI) and frontend (TypeScript/Vite)
# ============================================

# -------------------------
# Python / Backend
# -------------------------

# Virtual environments
.venv
venv/
env/
ENV/

# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints

# Poetry lock file
# NOTE: Best practice is to commit poetry.lock for reproducible builds
# Uncomment the next line ONLY if you don't want to commit the lock file
# poetry.lock

# Backend data directories (ignore contents but keep directory structure)
# NOTE: If you want to commit example data, comment out or remove the following lines
backend/data/dashboard/**/*
!backend/data/dashboard/**/.gitkeep
backend/data/events/
backend/data/analysis/
backend/data/config/

# -------------------------
# Node.js / Frontend
# -------------------------

# Dependencies
node_modules/

# Build outputs
dist/
build/
.out/

# Coverage
coverage/
.nyc_output/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime data
.pnp
.pnp.js

# Vite
.vite/
.vitest/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Optional REPL history
.node_repl_history

# Package manager lock files
# NOTE: Best practice is to commit lock files (package-lock.json) for reproducible builds
# Uncomment the following lines ONLY if you don't want to commit lock files
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# -------------------------
# Environment Variables
# -------------------------

# Backend environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Frontend environment files
.env.local
.env.development.local
.env.test.local
.env.production.local

# -------------------------
# IDE and Editor
# -------------------------

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr

# Vim
*.swp
*.swo
*~

# -------------------------
# Operating System Files
# -------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Linux
.directory

# Windows
Thumbs.db
Desktop.ini

# -------------------------
# Logs and Temporary Files
# -------------------------

# Log files
logs/
*.log

# Temporary files
tmp/
temp/

# -------------------------
# Miscellaneous
# -------------------------

# Lerna
lerna-debug.log*

# yarn v2
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*